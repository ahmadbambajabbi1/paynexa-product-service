# Copy to `.env` in this folder.
DATABASE_URL="postgresql://user:pass@localhost:5433/escrow_product_service"
RABBITMQ_URL=amqp://guest:guest@localhost:5672
INTERNAL_API_SECRET=change-me

PORT=5005

# Session resolution (same headers as gateway: Authorization + X-Device-Id).
USER_SERVICE_URL=http://127.0.0.1:5001

# Cloudflare R2 (S3-compatible). Required for product images (product_images/, product_image/) and
# marketplace services (service_cover/, service_images/).
# Endpoint is the account S3 API host (no bucket name in the path).
# Create S3 API credentials under R2 → Manage R2 API Tokens (Access Key ID + Secret Access Key).
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_REGION=auto
R2_BUCKET=your-bucket-name
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional: presigned GET TTL for listing product images (default 3600).
# R2_GET_URL_TTL_SECONDS=3600
